<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="550.0"
            prefWidth="800.0"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.cando_basededatos.ProductoController">

    <children>

        <Label layoutX="30.0"
               layoutY="20.0"
               text="Sistema de Productos"
               style="-fx-font-size:24px;
                      -fx-font-weight:bold;
                      -fx-text-fill:#db2777;" />

        <Label layoutX="30.0"
               layoutY="90.0"
               text="Nombre:" />

        <TextField fx:id="txtNombre"
                   layoutX="120.0"
                   layoutY="85.0"
                   prefWidth="200.0" />

        <Label layoutX="30.0"
               layoutY="140.0"
               text="Precio:" />

        <TextField fx:id="txtPrecio"
                   layoutX="120.0"
                   layoutY="135.0"
                   prefWidth="200.0" />

        <Label layoutX="30.0"
               layoutY="190.0"
               text="Stock:" />

        <TextField fx:id="txtStock"
                   layoutX="120.0"
                   layoutY="185.0"
                   prefWidth="200.0" />

        <Button text="Guardar"
                layoutX="370.0"
                layoutY="85.0"
                prefWidth="120.0"
                onAction="#guardar"/>

        <Button text="Mostrar"
                layoutX="370.0"
                layoutY="135.0"
                prefWidth="120.0"
                onAction="#mostrar"/>

        <Label fx:id="lblMensaje"
               layoutX="30.0"
               layoutY="240.0"
               style="-fx-text-fill:green;
                      -fx-font-weight:bold;" />

        <TableView fx:id="tablaProductos"
                   layoutX="30.0"
                   layoutY="280.0"
                   prefWidth="730.0"
                   prefHeight="220.0">

            <columns>

                <TableColumn fx:id="colId"
                             text="ID"
                             prefWidth="80"/>

                <TableColumn fx:id="colNombre"
                             text="Nombre"
                             prefWidth="250"/>

                <TableColumn fx:id="colPrecio"
                             text="Precio"
                             prefWidth="180"/>

                <TableColumn fx:id="colStock"
                             text="Stock"
                             prefWidth="180"/>

            </columns>

        </TableView>

    </children>

</AnchorPane>